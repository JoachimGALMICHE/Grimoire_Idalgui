<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grimoire Solaire — {{ app.user.username }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;500;600&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --gold-1: #fff8d0;
            --gold-2: #f5d060;
            --gold-3: #c9a84c;
            --gold-4: #7a5c1e;
            --gold-5: #3b2a0a;
            --gold-6: #1a0f00;
            --text-main: #f5e6a3;
            --text-sub: #c9a84c;
            --text-dim: #7a5c1e;
        }

        html { scroll-behavior: smooth; }

        body {
            min-height: 100vh;
            font-family: 'EB Garamond', serif;
            background: var(--gold-6);
            color: var(--text-main);
            overflow-x: hidden;
        }

        /* ===== BACKGROUND ===== */
        .bg-fixed {
            position: fixed;
            inset: 0;
            z-index: 0;
            background:
                radial-gradient(ellipse 100% 60% at 15% 0%, #f5d06025 0%, transparent 55%),
                radial-gradient(ellipse 70% 80% at 90% 100%, #c9a84c15 0%, transparent 60%),
                radial-gradient(ellipse 50% 40% at 50% 50%, #7a5c1e10 0%, transparent 70%),
                linear-gradient(170deg, #2a1a05 0%, #1a0f00 40%, #0a0600 100%);
        }

        /* Texture grain */
        .bg-fixed::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            opacity: 0.3;
            pointer-events: none;
        }

        /* Particules solaires */
        .particles { position: fixed; inset: 0; z-index: 1; pointer-events: none; }
        .particle {
            position: absolute;
            border-radius: 50%;
            animation: floatUp linear infinite;
            opacity: 0;
        }
        @keyframes floatUp {
            0%   { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            8%   { opacity: 1; }
            92%  { opacity: 0.4; }
            100% { transform: translateY(-10vh) rotate(540deg); opacity: 0; }
        }

        /* Grand orbe soleil */
        .sun-orb {
            position: fixed;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            top: -180px;
            right: -120px;
            background: radial-gradient(circle at 35% 35%, #fff8d0, #f5d060 35%, #c9a84c 60%, #7a5c1e 85%, transparent 100%);
            box-shadow: 0 0 80px #f5d06030, 0 0 200px #c9a84c15;
            z-index: 1;
            animation: sunPulse 8s ease-in-out infinite;
        }
        @keyframes sunPulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 80px #f5d06030, 0 0 200px #c9a84c15; }
            50% { transform: scale(1.03); box-shadow: 0 0 120px #f5d06040, 0 0 300px #c9a84c20; }
        }

        /* Rayons soleil */
        .sun-rays {
            position: fixed;
            top: -180px;
            right: -120px;
            width: 500px;
            height: 500px;
            z-index: 0;
            animation: raysRotate 40s linear infinite;
        }
        .sun-rays::before {
            content: '';
            position: absolute;
            inset: -100px;
            background: repeating-conic-gradient(
                from 0deg,
                #f5d06008 0deg,
                #f5d06008 3deg,
                transparent 3deg,
                transparent 12deg
            );
            border-radius: 50%;
        }
        @keyframes raysRotate { to { transform: rotate(360deg); } }

        /* ===== LAYOUT ===== */
        .page { position: relative; z-index: 10; }

        /* ===== HEADER ===== */
        header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.5rem 3rem;
            border-bottom: 1px solid #c9a84c15;
            backdrop-filter: blur(10px);
            background: rgba(26,15,0,0.3);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-brand {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .header-icon { font-size: 1.8rem; animation: sunPulse 4s ease-in-out infinite; }

        .header-title {
            font-family: 'Cinzel Decorative', serif;
            font-size: 0.9rem;
            color: var(--gold-3);
            letter-spacing: 0.05em;
        }

        .header-sub {
            font-family: 'Cinzel', serif;
            font-size: 0.6rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--text-dim);
            margin-top: 0.2rem;
        }

        .header-nav {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .header-user {
            font-family: 'Cinzel', serif;
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            color: var(--text-dim);
            text-transform: uppercase;
        }

        .btn-logout {
            font-family: 'Cinzel', serif;
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold-3);
            text-decoration: none;
            padding: 0.4rem 1rem;
            border: 1px solid #c9a84c30;
            border-radius: 2px;
            transition: all 0.3s;
        }
        .btn-logout:hover {
            background: #c9a84c15;
            border-color: #c9a84c60;
        }

        /* ===== HERO ===== */
        .hero {
            padding: 5rem 3rem 3rem;
            max-width: 1200px;
            margin: 0 auto;
            animation: fadeUp 1s ease both;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hero-eyebrow {
            font-family: 'Cinzel', serif;
            font-size: 0.65rem;
            letter-spacing: 0.4em;
            text-transform: uppercase;
            color: var(--text-dim);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .hero-eyebrow::before, .hero-eyebrow::after {
            content: '';
            flex: 0 0 40px;
            height: 1px;
            background: var(--text-dim);
        }

        .hero-title {
            font-family: 'Cinzel Decorative', serif;
            font-size: clamp(2rem, 5vw, 4rem);
            font-weight: 900;
            color: var(--gold-2);
            line-height: 1.1;
            margin-bottom: 0.5rem;
            text-shadow: 0 0 40px #f5d06040;
        }

        .hero-subtitle {
            font-family: 'Cinzel', serif;
            font-size: clamp(0.9rem, 2vw, 1.2rem);
            color: var(--gold-4);
            letter-spacing: 0.15em;
            margin-bottom: 2.5rem;
        }

        /* ===== FICHE PRÉSENTATION ===== */
        .fiche-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 4rem;
            animation: fadeUp 1s ease 0.2s both;
        }

        .fiche-card {
            background: linear-gradient(145deg, rgba(59,42,10,0.6) 0%, rgba(26,15,0,0.8) 100%);
            border: 1px solid #c9a84c25;
            border-radius: 3px;
            padding: 2rem;
            position: relative;
            overflow: hidden;
            transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
        }

        .fiche-card:hover {
            transform: translateY(-3px);
            border-color: #c9a84c50;
            box-shadow: 0 10px 40px #00000040, 0 0 20px #c9a84c10;
        }

        .fiche-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold-3), transparent);
        }

        /* Coins ornements */
        .fiche-card::after {
            content: attr(data-corner);
            position: absolute;
            top: 10px; right: 14px;
            font-size: 1.2rem;
            opacity: 0.3;
        }

        .fiche-tag {
            font-family: 'Cinzel', serif;
            font-size: 0.6rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--gold-3);
            background: #c9a84c15;
            border: 1px solid #c9a84c25;
            padding: 0.2rem 0.7rem;
            border-radius: 1px;
            display: inline-block;
            margin-bottom: 1rem;
        }

        .fiche-title {
            font-family: 'Cinzel Decorative', serif;
            font-size: 1.3rem;
            color: var(--gold-2);
            margin-bottom: 1rem;
        }

        .fiche-body {
            font-size: 0.95rem;
            line-height: 1.8;
            color: #d4bc7a;
            font-style: italic;
        }

        .fiche-body p + p { margin-top: 0.8rem; }

        .fiche-divider {
            width: 40px;
            height: 1px;
            background: linear-gradient(90deg, var(--gold-3), transparent);
            margin: 1.2rem 0;
        }

        .fiche-pillars {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .pillar {
            font-family: 'Cinzel', serif;
            font-size: 0.6rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--text-dim);
            border: 1px solid #7a5c1e30;
            padding: 0.25rem 0.6rem;
            border-radius: 1px;
        }

        /* ===== SÉPARATEUR SECTION ===== */
        .section-sep {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin: 3rem 0 2rem;
            animation: fadeUp 1s ease 0.3s both;
        }
        .section-sep-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, transparent, #c9a84c30, transparent);
        }
        .section-sep-text {
            font-family: 'Cinzel', serif;
            font-size: 0.65rem;
            letter-spacing: 0.35em;
            text-transform: uppercase;
            color: var(--text-dim);
        }
        .section-sep-symbol { color: var(--gold-3); font-size: 1rem; }

        /* ===== GRILLE DES MODULES ===== */
        .modules-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            max-width: 1200px;
            margin: 0 auto 5rem;
            padding: 0 3rem;
            animation: fadeUp 1s ease 0.4s both;
        }

        .module-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            padding: 2rem 1rem;
            background: linear-gradient(160deg, rgba(59,42,10,0.5) 0%, rgba(26,15,0,0.7) 100%);
            border: 1px solid #c9a84c20;
            border-radius: 3px;
            text-decoration: none;
            color: var(--text-main);
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(.4,0,.2,1);
            cursor: pointer;
            min-height: 140px;
        }

        .module-btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #c9a84c08, transparent);
            opacity: 0;
            transition: opacity 0.4s;
        }

        .module-btn::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold-3), transparent);
            transform: scaleX(0);
            transition: transform 0.4s;
        }

        .module-btn:hover {
            transform: translateY(-5px);
            border-color: #c9a84c45;
            box-shadow: 0 15px 40px #00000050, 0 0 30px #c9a84c08;
        }

        .module-btn:hover::before { opacity: 1; }
        .module-btn:hover::after { transform: scaleX(1); }

        .module-icon {
            font-size: 2.2rem;
            filter: drop-shadow(0 0 8px #c9a84c40);
            transition: transform 0.4s, filter 0.4s;
        }
        .module-btn:hover .module-icon {
            transform: scale(1.15) translateY(-3px);
            filter: drop-shadow(0 0 15px #f5d06060);
        }

        .module-name {
            font-family: 'Cinzel', serif;
            font-size: 0.7rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--gold-3);
            text-align: center;
        }

        .module-desc {
            font-size: 0.75rem;
            color: var(--text-dim);
            text-align: center;
            font-style: italic;
            line-height: 1.4;
        }

        /* Badge "bientôt" */
        .module-badge {
            position: absolute;
            top: 8px; right: 8px;
            font-family: 'Cinzel', serif;
            font-size: 0.5rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--text-dim);
            border: 1px solid #7a5c1e30;
            padding: 0.15rem 0.4rem;
            border-radius: 1px;
        }

        /* ===== FOOTER ===== */
        footer {
            position: relative;
            z-index: 10;
            text-align: center;
            padding: 2rem;
            border-top: 1px solid #c9a84c10;
            font-family: 'Cinzel', serif;
            font-size: 0.6rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #3b2a0a;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 900px) {
            .fiche-grid { grid-template-columns: 1fr; }
            .modules-grid { grid-template-columns: repeat(2, 1fr); padding: 0 1.5rem; }
            header { padding: 1rem 1.5rem; }
            .hero { padding: 3rem 1.5rem 2rem; }
        }

        @media (max-width: 500px) {
            .modules-grid { grid-template-columns: repeat(2, 1fr); }
            .header-title { font-size: 0.75rem; }
        }
    </style>
</head>
<body>
    <div class="bg-fixed"></div>
    <div class="sun-rays"></div>
    <div class="sun-orb"></div>
    <div class="particles" id="particles"></div>

    <div class="page">
        <!-- HEADER -->
        <header>
            <div class="header-brand">
                <span class="header-icon">☀️</span>
                <div>
                    <div class="header-title">Grimoire Idalgui</div>
                    <div class="header-sub">Voie Solaire · Druidisme</div>
                </div>
            </div>
            <nav class="header-nav">
                <span class="header-user">✦ {{ app.user.username }}</span>
                <a href="{{ path('app_logout') }}" class="btn-logout">Quitter</a>
            </nav>
        </header>

        <!-- HERO -->
        <div class="hero">
            <div class="hero-eyebrow">Voie du Soleil</div>
            <h1 class="hero-title">Grimoire<br>Solaire</h1>
            <p class="hero-subtitle">Druidisme & Néodruidisme</p>

            <!-- FICHES PRÉSENTATION -->
            <div class="fiche-grid">

                <!-- Fiche Druidisme -->
                <div class="fiche-card" data-corner="☀">
                    <span class="fiche-tag">Tradition Ancienne</span>
                    <h2 class="fiche-title">Le Druidisme</h2>
                    <div class="fiche-body">
                        <p>Le Druidisme est la tradition spirituelle et philosophique des anciens Celtes, portée par les druides — gardiens du savoir, de la loi et du lien entre le monde des vivants et celui des esprits.</p>
                        <div class="fiche-divider"></div>
                        <p>Profondément ancré dans les cycles solaires, il célèbre la roue de l'année à travers huit sabbats : les solstices, les équinoxes et les quatre fêtes de feu gaéliques. La nature est temple, l'arbre est maître.</p>
                    </div>
                    <div class="fiche-pillars">
                        <span class="pillar">Roue de l'année</span>
                        <span class="pillar">Ogham</span>
                        <span class="pillar">Nemeton</span>
                        <span class="pillar">Awen</span>
                        <span class="pillar">Triskèle</span>
                    </div>
                </div>

                <!-- Fiche Néodruidisme -->
                <div class="fiche-card" data-corner="🌿">
                    <span class="fiche-tag">Renouveau Contemporain</span>
                    <h2 class="fiche-title">Le Néodruidisme</h2>
                    <div class="fiche-body">
                        <p>Né au XVIIIe siècle et florissant de nos jours, le Néodruidisme réinterprète les enseignements druidiques pour notre époque. Il mêle écologie sacrée, philosophie celto-chamanique et quête personnelle du divin.</p>
                        <div class="fiche-divider"></div>
                        <p>Il embrasse la pluralité des voies — de l'OBOD à l'ADF — et place la relation vivante avec la terre, les ancêtres et les esprits de la nature au cœur de la pratique quotidienne.</p>
                    </div>
                    <div class="fiche-pillars">
                        <span class="pillar">OBOD</span>
                        <span class="pillar">Barderie</span>
                        <span class="pillar">Ovatie</span>
                        <span class="pillar">Druidecht</span>
                        <span class="pillar">Écologie sacrée</span>
                    </div>
                </div>

            </div>

            <!-- SÉPARATEUR -->
            <div class="section-sep">
                <div class="section-sep-line"></div>
                <span class="section-sep-symbol">✦</span>
                <span class="section-sep-text">Les Portes du Grimoire</span>
                <span class="section-sep-symbol">✦</span>
                <div class="section-sep-line"></div>
            </div>
        </div>

        <!-- MODULES -->
        <div class="modules-grid">

            <a href="{{ path('bestiaire_index') }}" class="module-btn">
                <span class="module-icon">🐉</span>
                <span class="module-name">Bestiaire</span>
                <span class="module-desc">Créatures & esprits des bois</span>
            </a>

            <a href="{{ path('pp_index') }}" class="module-btn">
                <span class="module-icon">🌿</span>
                <span class="module-name">Plantes & Pierres</span>
                <span class="module-desc">Vertus & correspondances</span>
            </a>

            <a href="#" class="module-btn">
                <span class="module-badge">bientôt</span>
                <span class="module-icon">🛠️</span>
                <span class="module-name">Outils</span>
                <span class="module-desc">Instruments rituels</span>
            </a>

            <a href="#" class="module-btn">
                <span class="module-badge">bientôt</span>
                <span class="module-icon">🗺️</span>
                <span class="module-name">Plans d'Existence</span>
                <span class="module-desc">Carte des mondes</span>
            </a>

            <a href="#" class="module-btn">
                <span class="module-badge">bientôt</span>
                <span class="module-icon">📅</span>
                <span class="module-name">Calendrier</span>
                <span class="module-desc">Sabbats & éphémérides</span>
            </a>

            <a href="#" class="module-btn">
                <span class="module-badge">bientôt</span>
                <span class="module-icon">🏪</span>
                <span class="module-name">Marché</span>
                <span class="module-desc">Objets & stock magique</span>
            </a>

            <a href="#" class="module-btn">
                <span class="module-badge">bientôt</span>
                <span class="module-icon">✨</span>
                <span class="module-name">Sorts & Rituels</span>
                <span class="module-desc">Pratiques & cérémonies</span>
            </a>

            <a href="#" class="module-btn">
                <span class="module-badge">bientôt</span>
                <span class="module-icon">📖</span>
                <span class="module-name">Fiches Magiques</span>
                <span class="module-desc">Définitions & savoirs</span>
            </a>

        </div>

        <footer>
            Grimoire Idalgui · Voie Solaire · Les secrets restent entre les murs du grimoire
        </footer>
    </div>

    <script>
        // Particules solaires
        function createParticle() {
            const p = document.createElement('div');
            p.classList.add('particle');
            const size = Math.random() * 3 + 1;
            p.style.cssText = `
                width: ${size}px;
                height: ${size}px;
                left: ${Math.random() * 100}vw;
                animation-duration: ${Math.random() * 20 + 12}s;
                animation-delay: ${Math.random() * 8}s;
                background: hsl(${38 + Math.random() * 15}, 85%, ${55 + Math.random() * 25}%);
                box-shadow: 0 0 ${size * 4}px hsl(${38 + Math.random() * 15}, 85%, 65%);
            `;
            document.getElementById('particles').appendChild(p);
            setTimeout(() => p.remove(), 28000);
        }

        for (let i = 0; i < 15; i++) setTimeout(createParticle, i * 600);
        setInterval(createParticle, 2500);
    </script>
</body>
</html>
