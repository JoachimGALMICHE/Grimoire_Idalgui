<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plantes & Pierres Lunaires — Grimoire Idalgui</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;500;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
        :root { --s1:#f0f4ff; --s2:#c8d4f0; --s3:#8a94b0; --s4:#3a4060; --s5:#1a2040; --s6:#0d1020; }
        body { min-height:100vh; font-family:'EB Garamond',serif; background:var(--s6); color:var(--s2); overflow-x:hidden; }

        .bg-fixed { position:fixed; inset:0; z-index:0; background: radial-gradient(ellipse 70% 50% at 20% 0%, #2a0a4a25 0%, transparent 55%), linear-gradient(170deg, #0f0820 0%, #0d1020 40%, #060810 100%); }
        .stars { position:fixed; inset:0; z-index:0; background-image: radial-gradient(1px 1px at 8% 12%,#fff 0%,transparent 100%), radial-gradient(1.5px 1.5px at 25% 35%,#eef 0%,transparent 100%), radial-gradient(1px 1px at 50% 8%,#fff 0%,transparent 100%), radial-gradient(1px 1px at 72% 55%,#dde 0%,transparent 100%), radial-gradient(2px 2px at 88% 22%,#fff 0%,transparent 100%), radial-gradient(1px 1px at 15% 80%,#eef 0%,transparent 100%); opacity:0.65; }
        .moon-orb { position:fixed; width:380px; height:380px; border-radius:50%; top:-130px; right:-90px; z-index:1; background:radial-gradient(circle at 40% 35%,#f0f4ff,#c8d4f0 40%,#8a94b0 65%,#3a4060 85%,transparent 100%); box-shadow:0 0 60px #c8d4f018; animation:moonGlow 10s ease-in-out infinite; }
        @keyframes moonGlow { 0%,100%{box-shadow:0 0 60px #c8d4f018} 50%{box-shadow:0 0 100px #c8d4f025} }
        @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }

        .page { position:relative; z-index:10; max-width:1200px; margin:0 auto; padding:0 2rem 4rem; }

        header { position:sticky; top:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:1.2rem 2rem; margin:0 -2rem; background:rgba(13,16,32,0.88); backdrop-filter:blur(12px); border-bottom:1px solid #8a94b015; }
        .header-left { display:flex; align-items:center; gap:1rem; }
        .btn-back { font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--s4); text-decoration:none; padding:0.4rem 0.8rem; border:1px solid #3a406030; border-radius:2px; transition:all 0.3s; }
        .btn-back:hover { color:var(--s3); border-color:#8a94b050; }
        .header-title { font-family:'Cinzel Decorative',serif; font-size:1rem; color:var(--s3); }
        .header-sub { font-family:'Cinzel',serif; font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--s4); }

        .hero { padding:3rem 0 2rem; animation:fadeUp 0.8s ease both; }
        .hero-eyebrow { font-family:'Cinzel',serif; font-size:0.6rem; letter-spacing:0.4em; text-transform:uppercase; color:var(--s4); margin-bottom:0.8rem; display:flex; align-items:center; gap:1rem; }
        .hero-eyebrow::before, .hero-eyebrow::after { content:''; flex:0 0 30px; height:1px; background:var(--s4); }
        .hero-title { font-family:'Cinzel Decorative',serif; font-size:2.5rem; color:var(--s2); margin-bottom:0.3rem; text-shadow:0 0 30px #c8d4f020; }

        .tabs { display:flex; gap:0; margin-bottom:2.5rem; border-bottom:1px solid #8a94b020; animation:fadeUp 0.8s ease 0.1s both; }
        .tab-btn { font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; padding:0.9rem 2rem; background:transparent; border:none; cursor:pointer; color:var(--s4); position:relative; transition:color 0.3s; text-decoration:none; display:block; }
        .tab-btn::after { content:''; position:absolute; bottom:-1px; left:0; right:0; height:2px; background:var(--s3); transform:scaleX(0); transition:transform 0.3s; }
        .tab-btn:hover { color:var(--s3); }
        .tab-btn.active { color:var(--s2); }
        .tab-btn.active::after { transform:scaleX(1); }

        .actions-bar { display:flex; align-items:center; gap:1rem; margin-bottom:2rem; flex-wrap:wrap; animation:fadeUp 0.8s ease 0.15s both; }
        .search-wrap { position:relative; flex:1; min-width:200px; }
        .search-input { width:100%; padding:0.7rem 1rem 0.7rem 2.5rem; background:rgba(26,32,64,0.4); border:1px solid #8a94b020; border-radius:2px; font-family:'EB Garamond',serif; font-size:0.95rem; color:var(--s2); outline:none; transition:border-color 0.3s; }
        .search-input:focus { border-color:#8a94b050; box-shadow:0 0 0 2px #8a94b010; }
        .search-input::placeholder { opacity:0.35; }
        .search-icon { position:absolute; left:0.8rem; top:50%; transform:translateY(-50%); color:var(--s4); }
        .btn-new { display:flex; align-items:center; gap:0.5rem; font-family:'Cinzel',serif; font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; text-decoration:none; padding:0.7rem 1.4rem; background:linear-gradient(135deg,#3a4060,#1a2040); color:var(--s2); border:1px solid #8a94b030; border-radius:2px; transition:all 0.3s; white-space:nowrap; }
        .btn-new:hover { transform:translateY(-2px); box-shadow:0 8px 30px #8a94b030; }

        .items-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1.2rem; animation:fadeUp 0.8s ease 0.2s both; }
        .item-card { background:linear-gradient(145deg,rgba(26,32,64,0.55) 0%,rgba(13,16,32,0.88) 100%); border:1px solid #8a94b018; border-radius:3px; padding:1.5rem; position:relative; overflow:hidden; transition:all 0.4s cubic-bezier(.4,0,.2,1); text-decoration:none; color:inherit; display:block; }
        .item-card::before { content:''; position:absolute; top:0;left:0;right:0; height:2px; background:linear-gradient(90deg,transparent,var(--s3),transparent); }
        .item-card:hover { transform:translateY(-4px); border-color:#8a94b038; box-shadow:0 12px 40px #00000060; }

        .card-categorie { font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.25em; text-transform:uppercase; color:var(--s4); background:#8a94b010; border:1px solid #8a94b018; padding:0.15rem 0.5rem; border-radius:1px; display:inline-block; margin-bottom:0.8rem; }
        .card-nom { font-family:'Cinzel Decorative',serif; font-size:1.1rem; color:var(--s2); margin-bottom:0.3rem; }
        .card-origine { font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.1em; color:var(--s4); margin-bottom:0.8rem; font-style:italic; }
        .card-desc { font-size:0.88rem; color:#8a9ab8; line-height:1.6; font-style:italic; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
        .card-tags { display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.8rem; }
        .card-tag { font-family:'Cinzel',serif; font-size:0.5rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--s4); border:1px solid #3a406025; padding:0.15rem 0.4rem; border-radius:1px; }
        .card-footer { display:flex; justify-content:space-between; align-items:center; margin-top:1rem; padding-top:0.8rem; border-top:1px solid #8a94b012; }
        .card-date { font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.1em; color:#1a2040; }

        .empty-state { grid-column:1/-1; text-align:center; padding:5rem 2rem; }
        .empty-icon { font-size:4rem; margin-bottom:1.5rem; opacity:0.3; }
        .empty-title { font-family:'Cinzel Decorative',serif; font-size:1.2rem; color:var(--s4); margin-bottom:0.8rem; }
        .empty-text { font-size:0.9rem; color:#1a2040; font-style:italic; margin-bottom:2rem; }
    </style>
</head>
<body>
<div class="bg-fixed"></div>
<div class="stars"></div>
<div class="moon-orb"></div>

<div class="page">
    <header>
        <div class="header-left">
            <a href="{{ path('app_home') }}" class="btn-back">← Grimoire</a>
            <div>
                <div class="header-title">🌙 Plantes & Pierres</div>
                <div class="header-sub">Voie Lunaire · Correspondances sacrées</div>
            </div>
        </div>
    </header>

    <div class="hero">
        <div class="hero-eyebrow">Voie Lunaire</div>
        <h1 class="hero-title">Plantes & Pierres</h1>
    </div>

    <div class="tabs">
        <a href="{{ path('pp_index', {onglet: 'plante', q: search}) }}" class="tab-btn {{ onglet == 'plante' ? 'active' : '' }}">
            <span>🌙</span> Plantes
        </a>
        <a href="{{ path('pp_index', {onglet: 'pierre', q: search}) }}" class="tab-btn {{ onglet == 'pierre' ? 'active' : '' }}">
            <span>🔮</span> Pierres
        </a>
    </div>

    <div class="actions-bar">
        <form method="get" action="{{ path('pp_index') }}" style="flex:1;display:flex;gap:1rem;flex-wrap:wrap;">
            <input type="hidden" name="onglet" value="{{ onglet }}">
            <div class="search-wrap">
                <span class="search-icon">🔍</span>
                <input type="text" name="q" value="{{ search }}" class="search-input" placeholder="Rechercher une {{ onglet == 'plante' ? 'plante' : 'pierre' }}...">
            </div>
        </form>
        <a href="{{ path('pp_new', {categorie: onglet}) }}" class="btn-new">
            ✦ Nouvelle {{ onglet == 'plante' ? 'Plante' : 'Pierre' }}
        </a>
    </div>

    <div class="items-grid">
        {% if items is empty %}
            <div class="empty-state">
                <div class="empty-icon">{{ onglet == 'plante' ? '🌙' : '🔮' }}</div>
                <div class="empty-title">Aucune {{ onglet == 'plante' ? 'plante' : 'pierre' }} répertoriée</div>
                <p class="empty-text">Commence par créer ta première fiche.</p>
                <a href="{{ path('pp_new', {categorie: onglet}) }}" class="btn-new" style="display:inline-flex">✦ Créer la première fiche</a>
            </div>
        {% else %}
            {% for item in items %}
            <a href="{{ path('pp_show', {id: item.id}) }}" class="item-card">
                <span class="card-categorie">{{ item.categorie == 'plante' ? '🌙 Plante' : '🔮 Pierre' }}</span>
                <div class="card-nom">{{ item.nom }}</div>
                {% if item.origine %}<div class="card-origine">{{ item.origine }}</div>{% endif %}
                {% if item.description %}<p class="card-desc">{{ item.description }}</p>{% endif %}
                {% if item.correspondances %}
                    <div class="card-tags">
                        {% for tag in item.correspondances|split(',') %}
                            <span class="card-tag">{{ tag|trim }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
                <div class="card-footer">
                    <span></span>
                    <span class="card-date">{{ item.createdAt|date('d/m/Y') }}</span>
                </div>
            </a>
            {% endfor %}
        {% endif %}
    </div>
</div>
</body>
</html>
